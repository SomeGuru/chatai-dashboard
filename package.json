{
  "name": "chatai-dashboard",
  "version": "3.2.1",
  "description": "ChatAI Dashboard - Your gateway to every AI model, by IT2Innovations / TheLarios Designs",
  "main": "main.js",
  "author": {
    "name": "Mike Larios - IT2Innovations / TheLarios Designs",
    "email": "mike@thelarios.com",
    "url": "https://www.thelarios.com"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "start":       "electron .",
    "dev":         "electron . --inspect",
    "build":       "electron-builder --win --linux",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all":   "electron-builder --win --linux",
    "pack":        "electron-builder --dir"
  },
  "devDependencies": {
    "electron":         "^41.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.it2innovations.chatai-dashboard",
    "productName": "ChatAI Dashboard",
    "copyright": "Copyright c 2026 IT2Innovations / TheLarios Designs",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "!**/*.map",
      "!**/node_modules/**"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "IT2Innovations",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "shortcutName": "ChatAI Dashboard",
      "license": "LICENSE",
      "installerSidebar": "build-resources/sidebar.bmp",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "icon": "assets/icons/",
      "category": "Network",
      "description": "ChatAI Dashboard - access every major AI from one elegant app",
      "maintainer": "Mike Larios <mike@thelarios.com>",
      "desktop": {
        "Name": "ChatAI Dashboard",
        "Comment": "Your gateway to every AI model",
        "Categories": "Network;Utility;"
      }
    },
    "appImage": {
      "artifactName": "ChatAI-Dashboard-${version}.AppImage"
    },
    "deb": {
      "artifactName": "ChatAI-Dashboard-${version}.deb",
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils", "libatspi2.0-0", "libuuid1"]
    },
    "portable": {
      "artifactName": "ChatAI-Dashboard-${version}-Portable.exe"
    },
    "publish": "never",
    "compression": "maximum",
    "removePackageScripts": true
  }
}
